# Local Development
# Point to your service account JSON file
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# Google Cloud project ID (required)
GOOGLE_CLOUD_PROJECT=your-project-id

# Firestore database ID (required)
FIRESTORE_DATABASE_ID=your-database-id

# Google Cloud Storage bucket for enclosures
GCS_BUCKET_NAME=your-bucket-name

# Google Cloud Storage bucket for user uploads (public)
GCS_UPLOAD_BUCKET_NAME=your-uploads-bucket

# CORS configuration (comma-separated origins)
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Base URL for absolute URLs, e.g. uploaded images
API_BASE_URL=http://localhost:4000

# Upload pipeline configuration
# Timeouts in ms, sizes in bytes, dimensions in pixels
UPLOAD_TIMEOUT_MS=60000
UPLOAD_MAX_FILE_SIZE_BYTES=10485760
UPLOAD_MIN_DIMENSION_PX=320
UPLOAD_MAX_DIMENSION_PX=5000
UPLOAD_RATE_LIMIT_PER_USER=20
UPLOAD_RATE_LIMIT_GLOBAL=100
UPLOAD_DEFAULT_USER_QUOTA_BYTES=52428800
UPLOAD_QUOTA_CACHE_TTL_MS=30000
UPLOAD_QUOTA_CACHE_MAX_ENTRIES=500

# Firebase Auth Configuration
# Get these from Firebase Console -> Project Settings -> Your apps -> Web app
FIREBASE_API_KEY=your-firebase-api-key
# Optional: Firebase Auth Domain (defaults to projectId.firebaseapp.com)
# FIREBASE_AUTH_DOMAIN=your-auth-domain

# Production (Cloud Run / App Engine)
# No configuration needed - uses default service account
# 
# For Cloud Run with Secret Manager:
# 1. Store service account JSON in Secret Manager:
#    gcloud secrets create firebase-sa --data-file=service-account.json
# 
# 2. Mount the secret as a file in Cloud Run:
#    gcloud run deploy --set-secrets="/secrets/firebase-sa=firebase-sa:latest"
# 
# 3. Set environment variable in Cloud Run:
#    --set-env-vars="GOOGLE_APPLICATION_CREDENTIALS=/secrets/firebase-sa"

POSTMARK_SERVER_TOKEN=your-postmark-server-token
POSTMARK_FROM_EMAIL=noreply@example.com

# JSON body size limit in bytes (default: 2 MB)
# JSON_BODY_LIMIT_BYTES=2097152

# Hosted RichPods configuration
GCS_HOSTED_BUCKET_NAME=your-hosted-bucket
# Optional: Override default limits
# HOSTED_MP3_MAX_FILE_SIZE_BYTES=52428800
# HOSTED_IMAGE_MAX_FILE_SIZE_BYTES=5242880
# HOSTED_MP3_MAX_DURATION_MINUTES=150
# HOSTED_MP3_MAX_BITRATE_KBPS=256
