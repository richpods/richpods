{
    "name": "@richpods/server",
    "version": "1.0.0",
    "private": true,
    "type": "module",
    "devDependencies": {
        "@graphql-codegen/cli": "catalog:",
        "@graphql-codegen/typescript": "catalog:",
        "@graphql-codegen/typescript-resolvers": "catalog:",
        "@tsconfig/node24": "catalog:",
        "@types/cheerio": "0.22.35",
        "@types/cors": "2.8.19",
        "@types/express": "5.0.1",
        "@types/geojson": "7946.0.16",
        "@types/joi": "17.2.2",
        "@types/multer": "2.0.0",
        "@types/node": "catalog:",
        "@types/uuid": "10.0.0",
        "@types/xml2js": "0.4.14",
        "concurrently": "8.2.2",
        "copyfiles": "2.4.1",
        "firebase-tools": "15.5.1",
        "prettier": "3.6.2",
        "rimraf": "6.0.1",
        "tsc-alias": "1.8.16",
        "tsx": "4.19.2",
        "typescript": "catalog:"
    },
    "dependencies": {
        "@google-cloud/firestore": "7.11.6",
        "@google-cloud/storage": "7.17.2",
        "@richpods/shared": "workspace:*",
        "cheerio": "1.1.2",
        "cors": "2.8.5",
        "dotenv": "17.2.1",
        "entities": "7.0.1",
        "express": "5.1.0",
        "file-type": "21.0.0",
        "firebase": "catalog:",
        "firebase-admin": "13.6.0",
        "got": "14.4.8",
        "graphql": "catalog:",
        "graphql-http": "1.22.4",
        "graphql-scalars": "1.24.2",
        "joi": "18.0.1",
        "multer": "2.0.2",
        "postmark": "4.0.5",
        "rate-limiter-flexible": "8.0.1",
        "ruru": "2.0.0-beta.22",
        "sharp": "0.34.5",
        "uuid": "11.1.0",
        "xml2js": "0.6.2"
    },
    "scripts": {
        "clean": "rimraf build",
        "build:shared": "tsc -p ../shared/tsconfig.json",
        "dev": "pnpm run build:shared && pnpm run codegen && pnpm run copyfiles && concurrently \"pnpm run build:watch\" \"node --watch-path build build/src/server.js\"",
        "build:info": "printf '{\"commitHash\":\"%s\"}\\n' \"$(git rev-parse --short HEAD)\" > build/build-info.json 2>/dev/null || true",
        "build": "pnpm run build:shared && pnpm run codegen && tsc -p tsconfig.json && pnpm run copyfiles && pnpm run build:info",
        "build:run": "pnpm run build && node build/src/server.js",
        "build:watch": "tsc -w -p tsconfig.json",
        "codegen": "graphql-codegen",
        "copyfiles": "copyfiles schema.graphql ./build",
        "deploy:indexes": "pnpm exec firebase deploy --only firestore:indexes",
        "format:check": "prettier --check \"**/*.{ts,js,json}\" --ignore-path .gitignore",
        "set-user-role": "tsx scripts/set-user-role.ts",
        "test": "node --import tsx --test \"tests/**/*.test.ts\"",
        "test:watch": "node --import tsx --test --watch \"tests/**/*.test.ts\""
    }
}
